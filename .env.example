# Port published on the host (and inside the container).
PORT=8080

# The base URL your IDE will use to reach the gateway. This value is embedded in
# the exported MCP config. Keep the localhost default for a local IDE.
PUBLIC_BASE_URL=http://localhost:8080

# How many times a single upstream tool call is retried before it is SKIPPED
# (so one broken upstream cannot deadlock a branch).
MAX_TOOL_RETRIES=3

# Safety-net reset: if > 0, a session's progress resets after this many ms of
# inactivity. 0 disables it (progress then only resets when the whole tree
# completes). Example: 1800000 = 30 minutes.
IDLE_RESET_MS=0
